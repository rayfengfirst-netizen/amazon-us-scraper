# 请求间隔（秒），降低对站点的请求频率
AMAZON_REQUEST_DELAY_SEC=1.0

# 可选：自定义 User-Agent（留空则使用内置桌面浏览器 UA）
# AMAZON_USER_AGENT=

# --- ScraperAPI Structured Amazon Product（美国站）---
SCRAPERAPI_KEY=

# 默认使用「同步」GET: https://api.scraperapi.com/structured/amazon/product （稳定，避免异步轮询 404）
# 若必须使用异步 POST + 轮询，再设置：
# SCRAPERAPI_USE_ASYNC=1
# 异步时必填 callback URL；未配置则使用内置占位 https://httpbin.org/post
# SCRAPERAPI_WEBHOOK_URL=https://webhook.site/你的uuid
# 同步请求超时（秒），默认 120
# SCRAPERAPI_SYNC_TIMEOUT_SEC=120
# 可选覆盖（默认 us + com）
# SCRAPERAPI_COUNTRY_CODE=us
# SCRAPERAPI_TLD=com

# --- Shopify（通过 Web「店铺设置」录入，不写在此文件）---
# 可选：店铺后台「开发应用」的 shpat_ token，或 Dev Dashboard 的 Client ID + Secret（OAuth client_credentials）
# scopes 建议：read_products, write_products, read_publications, write_publications

# --- OpenAI 文案优化（可选，发布时生效）---
# 开关：1/true 开启；未开启则使用本地规则文案
# OPENAI_ENABLE=0
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.4
# OPENAI_TIMEOUT_SEC=60

# --- 访问保护（可选，建议线上开启）---
# 开启后，除 /health 外所有页面与接口都需要 HTTP Basic 登录
# APP_BASIC_AUTH_ENABLE=1
# APP_BASIC_AUTH_USERNAME=admin
# APP_BASIC_AUTH_PASSWORD=change_this_to_a_strong_password
