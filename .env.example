# 请求间隔（秒），降低对站点的请求频率
AMAZON_REQUEST_DELAY_SEC=1.0

# 可选：自定义 User-Agent（留空则使用内置桌面浏览器 UA）
# AMAZON_USER_AGENT=

# --- ScraperAPI Structured Amazon Product（美国站）---
SCRAPERAPI_KEY=

# 默认使用「同步」GET: https://api.scraperapi.com/structured/amazon/product （稳定，避免异步轮询 404）
# 若必须使用异步 POST + 轮询，再设置：
# SCRAPERAPI_USE_ASYNC=1
# 异步时必填 callback URL；未配置则使用内置占位 https://httpbin.org/post
# SCRAPERAPI_WEBHOOK_URL=https://webhook.site/你的uuid
# 同步请求超时（秒），默认 120
# SCRAPERAPI_SYNC_TIMEOUT_SEC=120
# 可选覆盖（默认 us + com）
# SCRAPERAPI_COUNTRY_CODE=us
# SCRAPERAPI_TLD=com
